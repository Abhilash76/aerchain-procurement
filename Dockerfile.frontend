# Dockerfile.frontend
# Stage 1: Build the React application
FROM node:20-slim AS builder

WORKDIR /app

ARG VITE_ANALYSIS_SERVER=http://localhost:8765
ARG VITE_OLLAMA_CHAT_URL=http://localhost:11434/api/chat
ENV VITE_ANALYSIS_SERVER=$VITE_ANALYSIS_SERVER
ENV VITE_OLLAMA_CHAT_URL=$VITE_OLLAMA_CHAT_URL

# Copy package files and install dependencies
COPY package*.json ./
RUN npm install

# Copy the rest of the application code
COPY . .

# Build the application for production
RUN npm run build

# Stage 2: Serve the application using Nginx
FROM nginx:alpine

COPY nginx.frontend.conf /etc/nginx/conf.d/default.conf

# Copy build artifacts from stage 1
COPY --from=builder /app/dist /usr/share/nginx/html

# Expose port 80 for the web traffic
EXPOSE 80

# Start Nginx
CMD ["nginx", "-g", "daemon off;"]
